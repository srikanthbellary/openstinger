# ============================================================
# OpenStinger Environment Variables — copy to .env and fill in
# ============================================================

# --- Anthropic ---
ANTHROPIC_API_KEY=sk-ant-...

# --- OpenAI (for embeddings if using OpenAI embedder) ---
# OPENAI_API_KEY=sk-...

# --- FalkorDB connection ---
FALKORDB_HOST=localhost
FALKORDB_PORT=6379
FALKORDB_PASSWORD=
# For FalkorDB Cloud:
# FALKORDB_HOST=your-instance.falkordb.io
# FALKORDB_PORT=6379
# FALKORDB_PASSWORD=your-cloud-password

# --- FalkorDB Browser (session signing — set any random string) ---
NEXTAUTH_SECRET=change-me-generate-with-openssl-rand-base64-32

# --- PostgreSQL (used by docker compose) ---
POSTGRES_PASSWORD=your_postgres_password

# --- Operational DB ---
# SQLite (default) — path relative to harness root
OPENSTINGER_DB_PATH=.openstinger/openstinger.db
# PostgreSQL (optional upgrade) — uncomment and set:
# OPENSTINGER_DB_URL=postgresql+asyncpg://openstinger:your_postgres_password@localhost:5432/openstinger

# --- Agent identity ---
OPENSTINGER_AGENT_NAME=default

# --- Log level ---
OPENSTINGER_LOG_LEVEL=INFO

# --- MCP transport ---
# stdio (default) or tcp
OPENSTINGER_MCP_TRANSPORT=stdio
# TCP port (only used if transport=tcp)
OPENSTINGER_MCP_TCP_PORT=8765
